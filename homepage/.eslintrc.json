{
  "env": {
    "browser": true,
    "es2020": true
  },
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "error",
    "no-undef": "error",
    "eqeqeq": "error",
    "no-console": "warn"
  },
  "overrides": [
    {
      "files": ["js/services.js"],
      "env": {
        "node": true
      }
    },
    {
      "files": ["js/__tests__/**/*.js"],
      "env": {
        "node": true,
        "jest": true
      }
    }
  ]
}
