# ===================
# User & System
# ===================
# User ID for file permissions (run `id -u` to find yours)
PUID=${userId}

# Group ID for file permissions (run `id -g` to find yours)
PGID=${userGroupId}

# Timezone (e.g., America/New_York, Europe/London, Australia/Sydney)
TZ=${timezone}

# Subdomain TLD for per-service hostnames (plex.<TLD>, radarr.<TLD>, ...).
# Default `local` works on Bonjour/mDNS networks; use something else
# (e.g. `home`, `lan`) on DNS-based LANs.
SUBDOMAIN_TLD=${subdomainTld}

# ===================
# Paths
# ===================
# Path to store service configuration files
DOCKER_CONFIG=${localPathToConfigDirectory}

# Path to your media library root (should contain movies/, tv/, downloads/)
DOCKER_MEDIA=${localPathToMediaDirectory}

# ===================
# Plex
# ===================
# Plex claim token - get one from https://plex.tv/claim (expires in 4 minutes)
PLEX_CLAIM=${plex_claim}
