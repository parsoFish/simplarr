# =============================================================================
# Simplarr — Environment Configuration Reference
# =============================================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# This file is the canonical reference for all configurable variables.
# Every key defined here is a supported override for setup.sh and configure.sh.
#
# =============================================================================

# =============================================================================
# SERVICE PORT NUMBERS
# =============================================================================
# Default ports for each service. Override if you have conflicts.

RADARR_PORT=7878
SONARR_PORT=8989
PROWLARR_PORT=9696
QBITTORRENT_PORT=8080
OVERSEERR_PORT=5055
TAUTULLI_PORT=8181
PLEX_PORT=32400

# =============================================================================
# CONTAINER PATHS
# =============================================================================
# Paths inside containers where media directories are mounted.
# These must match the volume mappings in your docker-compose file.

MOVIES_PATH=/movies
TV_PATH=/tv
DOWNLOADS_PATH=/downloads

# =============================================================================
# WAIT / RETRY PARAMETERS
# =============================================================================
# Controls how long configure.sh waits for services to become ready.
# WAIT_MAX_ATTEMPTS: maximum number of health-check attempts before giving up
# WAIT_RETRY_SECS:   seconds to sleep between each attempt

WAIT_MAX_ATTEMPTS=30
WAIT_RETRY_SECS=2

# =============================================================================
# PLEX CONFIGURATION
# =============================================================================

# Plex claim token (from https://plex.tv/claim — valid for 4 minutes).
# Leave empty after initial setup; the token is only needed for first run.
PLEX_CLAIM=

# =============================================================================
# SUBDOMAIN TLD
# =============================================================================
# TLD used for the per-service hostnames (plex.<TLD>, radarr.<TLD>, ...).
# Default `local` works on mDNS-capable networks (macOS, iOS, Linux +
# avahi, Windows + Bonjour). Pick something else (e.g. `home`, `lan`, or
# your own) if your LAN uses DNS (Pi-hole, AdGuard Home, dnsmasq, router
# DNS) to resolve these names — `.local` works poorly through plain DNS
# on non-Apple devices.
#
# Whatever you pick, make sure your DNS points *.<TLD> at the host
# running the simplarr nginx reverse proxy.

SUBDOMAIN_TLD=local

# =============================================================================
# DOCKER CONFIG DIRECTORY
# =============================================================================
# Host path where service config files are stored.
# configure.sh reads API keys from XML/JSON files under this directory.

DOCKER_CONFIG=

# =============================================================================
# SPLIT TOPOLOGY — CROSS-HOST ROUTING (split+pi only)
# =============================================================================
# Only needed when running the Pi/Server half of a split deployment.
#
# NAS_IP
#   IP address of the NAS running Plex + qBittorrent. Used by setup.sh to
#   substitute YOUR_NAS_IP in nginx/split.conf.
#
# NAS_IP_DASHED
#   Same IP with '.' replaced by '-'. Plex's certificate is issued for
#   `<dashed-ip>.<hash>.plex.direct`, so Tautulli/Overseerr resolve via
#   this form. setup.sh derives it automatically from NAS_IP.
#
# PLEX_DIRECT_HASH
#   The 32-char hex hash in your Plex direct URL. Find it as the
#   CertificateUUID attribute in Plex's Preferences.xml, or look at
#   the hostname shown under Plex Settings → Network → Custom server
#   access URLs. Tautulli and Overseerr both need this to validate
#   TLS connections to Plex.

NAS_IP=
NAS_IP_DASHED=
PLEX_DIRECT_HASH=
